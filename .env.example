# Copy to .env and adjust. Used by docker-compose.
POSTGRES_DB=riskily_sme
POSTGRES_USER=riskily
POSTGRES_PASSWORD=riskily
POSTGRES_PORT=5432

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/riskily_sme
SPRING_DATASOURCE_USERNAME=riskily
SPRING_DATASOURCE_PASSWORD=riskily
SERVER_PORT=8080

# Auth (Sprint 1 step 4). Generate a strong 256-bit secret in real environments.
JWT_SECRET=change-me-dev-secret-change-me-dev-secret-32b
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# Third-Party Services — replace with your own keys, never commit real values
RESEND_API_KEY=your-resend-api-key-here
CLAUDE_API_KEY=your-anthropic-api-key-here
